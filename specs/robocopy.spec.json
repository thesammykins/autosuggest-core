{
  "name": "robocopy",
  "description": "Robust file and folder copy (Windows)",
  "options": [
    { "name": ["/S"], "description": "Copy subdirectories (excluding empty)" },
    { "name": ["/E"], "description": "Copy subdirectories including empty" },
    { "name": ["/LEV"], "description": "Copy only top N levels", "args": [{"name": "n"}] },
    { "name": ["/COPY"], "description": "Copy what file information", "args": [{"name": "flags"}] },
    { "name": ["/DCOPY"], "description": "Copy directory info", "args": [{"name": "flags"}] },
    { "name": ["/SEC"], "description": "Copy with security (equivalent to /COPY:DATS)" },
    { "name": ["/COPYALL"], "description": "Copy all file information" },
    { "name": ["/PURGE"], "description": "Delete dest files/dirs that no longer exist in source" },
    { "name": ["/MIR"], "description": "Mirror directory tree (equivalent to /E + /PURGE)" },
    { "name": ["/MOV"], "description": "Move files (delete from source)" },
    { "name": ["/MOVE"], "description": "Move files and dirs (delete from source)" },
    { "name": ["/A"], "description": "Copy only files with archive attribute set" },
    { "name": ["/M"], "description": "Copy only files with archive attribute and reset it" },
    { "name": ["/R"], "description": "Number of retries on failure", "args": [{"name": "n"}] },
    { "name": ["/W"], "description": "Wait time between retries (seconds)", "args": [{"name": "n"}] },
    { "name": ["/TBD"], "description": "Wait for share names to be defined" },
    { "name": ["/REG"], "description": "Save /R and /W as defaults in registry" },
    { "name": ["/NP"], "description": "No progress percentage" },
    { "name": ["/LOG"], "description": "Log to file (overwrite)", "args": [{"name": "file", "template": "filepaths"}] },
    { "name": ["/LOG+"], "description": "Log to file (append)", "args": [{"name": "file", "template": "filepaths"}] },
    { "name": ["/UNILOG"], "description": "Log to Unicode file (overwrite)", "args": [{"name": "file"}] },
    { "name": ["/UNILOG+"], "description": "Log to Unicode file (append)", "args": [{"name": "file"}] },
    { "name": ["/TEE"], "description": "Output to console and log file" },
    { "name": ["/NJH"], "description": "No job header" },
    { "name": ["/NJS"], "description": "No job summary" },
    { "name": ["/UNICODE"], "description": "Output in Unicode" },
    { "name": ["/BYTES"], "description": "Show sizes in bytes" },
    { "name": ["/L"], "description": "List only (no changes)" },
    { "name": ["/X"], "description": "Report extra files" },
    { "name": ["/V"], "description": "Verbose output" },
    { "name": ["/TS"], "description": "Include source timestamps" },
    { "name": ["/FP"], "description": "Include full paths" },
    { "name": ["/NDL"], "description": "No directory list" },
    { "name": ["/NFL"], "description": "No file list" },
    { "name": ["/MT"], "description": "Multi-threaded copy (N threads)", "args": [{"name": "n"}] },
    { "name": ["/A-"], "description": "Remove archive attribute from source", "args": [{"name": "attributes"}] },
    { "name": ["/XA"], "description": "Exclude files with attributes", "args": [{"name": "attributes"}] },
    { "name": ["/XF"], "description": "Exclude files matching patterns", "args": [{"name": "patterns"}] },
    { "name": ["/XD"], "description": "Exclude directories matching patterns", "args": [{"name": "patterns"}] },
    { "name": ["/XL"], "description": "Exclude 'lonely' files (present only in dest)" },
    { "name": ["/XN"], "description": "Exclude newer files" },
    { "name": ["/XO"], "description": "Exclude older files" },
    { "name": ["/XX"], "description": "Exclude extra files and dirs" },
    { "name": ["/IS"], "description": "Include same files" },
    { "name": ["/IT"], "description": "Include tweaked files" },
    { "name": ["/MAX"], "description": "Maximum file size", "args": [{"name": "n"}] },
    { "name": ["/MIN"], "description": "Minimum file size", "args": [{"name": "n"}] },
    { "name": ["/MAXAGE"], "description": "Maximum file age", "args": [{"name": "n"}] },
    { "name": ["/MINAGE"], "description": "Minimum file age", "args": [{"name": "n"}] },
    { "name": ["/MAXLAD"], "description": "Maximum last access date", "args": [{"name": "n"}] },
    { "name": ["/MINLAD"], "description": "Minimum last access date", "args": [{"name": "n"}] },
    { "name": ["/Z"], "description": "Copy in restartable mode" },
    { "name": ["/ZB"], "description": "Use restartable mode (fall back to backup)" },
    { "name": ["/EFSRAW"], "description": "Copy encrypted files in EFS RAW mode" },
    { "name": ["/IPG"], "description": "Inter-packet gap (ms)", "args": [{"name": "ms"}] },
    { "name": ["/RHS"], "description": "Turn on'Restartable, Hidden, System' semantics" },
    { "name": ["/NOOFFLOAD"], "description": "Don't use Windows copy offload" },
    { "name": ["/SL"], "description": "Don't follow symbolic links" },
    { "name": ["/RANGE"], "description": "Use only ports within range", "args": [{"name": "range"}] },
    { "name": ["/DND"], "description": "Do not copy DOS named streams" },
    { "name": ["/DST"], "description": "Correct DST time differences" },
    { "name": ["/XJ"], "description": "Exclude junction points" },
    { "name": ["/RUM"], "description": "Robocopy UI Mode" },
    { "name": ["/?", "--help"], "description": "Show help" }
  ],
  "args": [
    { "name": "source", "description": "Source directory", "template": "folders" },
    { "name": "destination", "description": "Destination directory", "template": "folders" },
    { "name": "files", "description": "File(s) to copy", "isOptional": true, "isVariadic": true }
  ]
}
