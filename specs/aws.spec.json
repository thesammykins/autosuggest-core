{
  "name": "aws",
  "description": "Amazon Web Services command-line interface",
  "requiresSubcommand": true,
  "options": [
    { "name": ["--profile"], "description": "Named profile to use", "args": [{"name": "name"}] },
    { "name": ["--region"], "description": "AWS region to use", "args": [{"name": "region"}] },
    { "name": ["--output"], "description": "Output format", "args": [{"name": "format", "suggestions": ["json", "text", "table", "yaml", "yaml-stream"]}] },
    { "name": ["--endpoint-url"], "description": "Custom service endpoint", "args": [{"name": "url"}] },
    { "name": ["--no-verify-ssl"], "description": "Disable SSL verification" },
    { "name": ["--no-paginate"], "description": "Disable pagination" },
    { "name": ["--debug"], "description": "Enable debug output" },
    { "name": ["--color"], "description": "Color output", "args": [{"name": "when", "suggestions": ["auto", "on", "off"]}] },
    { "name": ["--cli-connect-timeout"], "description": "Socket connect timeout", "args": [{"name": "seconds"}] },
    { "name": ["--cli-read-timeout"], "description": "Socket read timeout", "args": [{"name": "seconds"}] },
    { "name": ["--version"], "description": "Show version and exit" },
    { "name": ["--help"], "description": "Show help and exit" }
  ],
  "subcommands": [
    {
      "name": "s3",
      "description": "Amazon Simple Storage Service",
      "subcommands": [
        { "name": "ls", "description": "List S3 buckets or objects", "args": [{"name": "target", "isOptional": true}], "options": [
          { "name": ["--human-readable"], "description": "Display sizes in human-readable format" },
          { "name": ["--summarize"], "description": "Show total size and count" },
          { "name": ["--recursive"], "description": "Recursive listing" },
          { "name": ["--page-size"], "description": "Page size for results", "args": [{"name": "size"}] }
        ]},
        { "name": "cp", "description": "Copy objects between buckets or local paths", "args": [{"name": "source"}, {"name": "destination"}], "options": [
          { "name": ["--recursive"], "description": "Recursive copy" },
          { "name": ["--acl"], "description": "Canned ACL", "args": [{"name": "acl"}] },
          { "name": ["--no-follow-symlinks"], "description": "Don't follow symlinks" },
          { "name": ["--exclude"], "description": "Exclude patterns", "args": [{"name": "pattern"}] },
          { "name": ["--include"], "description": "Include patterns", "args": [{"name": "pattern"}] },
          { "name": ["--dryrun"], "description": "Show what would be copied" },
          { "name": ["--source-region"], "description": "Source bucket region", "args": [{"name": "region"}] },
          { "name": ["--grants"], "description": "Grant permissions", "args": [{"name": "grant"}] },
          { "name": ["--sse"], "description": "Server-side encryption", "args": [{"name": "algorithm"}] }
        ]},
        { "name": "mv", "description": "Move objects between buckets or local paths", "args": [{"name": "source"}, {"name": "destination"}], "options": [
          { "name": ["--recursive"], "description": "Recursive move" },
          { "name": ["--acl"], "description": "Canned ACL", "args": [{"name": "acl"}] },
          { "name": ["--exclude"], "description": "Exclude patterns", "args": [{"name": "pattern"}] },
          { "name": ["--include"], "description": "Include patterns", "args": [{"name": "pattern"}] },
          { "name": ["--dryrun"], "description": "Show what would be moved" }
        ]},
        { "name": "rm", "description": "Remove objects", "args": [{"name": "target"}], "options": [
          { "name": ["--recursive"], "description": "Recursive removal" },
          { "name": ["--exclude"], "description": "Exclude patterns", "args": [{"name": "pattern"}] },
          { "name": ["--include"], "description": "Include patterns", "args": [{"name": "pattern"}] },
          { "name": ["--dryrun"], "description": "Show what would be removed" }
        ]},
        { "name": "mb", "description": "Create an S3 bucket", "args": [{"name": "bucket"}], "options": [
          { "name": ["--region"], "description": "Bucket region", "args": [{"name": "region"}] }
        ]},
        { "name": "rb", "description": "Remove an S3 bucket", "args": [{"name": "bucket"}], "options": [
          { "name": ["--force"], "description": "Force removal" }
        ]},
        { "name": "sync", "description": "Sync directories to/from S3", "args": [{"name": "source"}, {"name": "destination"}], "options": [
          { "name": ["--delete"], "description": "Delete files not in source" },
          { "name": ["--exact-timestamps"], "description": "Use exact timestamps" },
          { "name": ["--exclude"], "description": "Exclude patterns", "args": [{"name": "pattern"}] },
          { "name": ["--include"], "description": "Include patterns", "args": [{"name": "pattern"}] },
          { "name": ["--dryrun"], "description": "Show what would be synced" },
          { "name": ["--acl"], "description": "Canned ACL", "args": [{"name": "acl"}] },
          { "name": ["--grants"], "description": "Grant permissions", "args": [{"name": "grant"}] }
        ]},
        { "name": "presign", "description": "Generate pre-signed URLs", "args": [{"name": "target"}], "options": [
          { "name": ["--expires-in"], "description": "Expiration in seconds", "args": [{"name": "seconds"}] }
        ]},
